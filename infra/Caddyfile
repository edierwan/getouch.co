{
  auto_https off
  admin off
}

:80 {
  respond "Unknown host." 421
}

(common_headers) {
  header {
    -Server
    -X-Powered-By
    Content-Security-Policy "base-uri 'self'; frame-ancestors 'self'; object-src 'none'; upgrade-insecure-requests"
    Permissions-Policy "accelerometer=(), autoplay=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()"
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
  }
}

(admin_auth) {
  basic_auth {
    {$ADMIN_AUTH_USER} {$ADMIN_AUTH_HASH}
  }
}

http://getouch.co {
  import common_headers

  @portal_admin path /admin /admin/*
  redir @portal_admin https://portal.getouch.co 308

  # Coolify webhook proxy — bypasses Cloudflare Access on coolify.getouch.co
  handle /webhooks/source/* {
    reverse_proxy coolify:8080 {
      header_up X-Forwarded-Proto https
    }
  }

  # Immutable hashed assets — cache aggressively
  @static path /_next/static/*
  header @static Cache-Control "public, max-age=31536000, immutable"

  # HTML pages — always revalidate
  @html path /
  header @html Cache-Control "public, max-age=0, must-revalidate"

  handle {
    reverse_proxy getouch-web:3000
  }
}

