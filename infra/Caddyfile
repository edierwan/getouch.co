# Protected vLLM API gateway. Implemented inside portal app at /v1/*, /health, /ready.
# llm.getouch.co is RESERVED for future LiteLLM and is NOT used here.
http://vllm.getouch.co {
  import common_headers

  @gateway path /v1/* /health /ready
  handle @gateway {
    reverse_proxy getouch-web-prod:3000
  }

  handle {
    respond "Not Found. Use /v1/models, /v1/chat/completions, /v1/embeddings, /health, /ready." 404
  }
}

