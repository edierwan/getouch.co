http://db.getouch.co {
  import common_headers
  reverse_proxy pgadmin:80
}

http://coolify.getouch.co {
  import common_headers

  # WebSocket path for Soketi real-time service
  @websocket {
    path /app/*
    header Connection *Upgrade*
    header Upgrade websocket
  }
  handle @websocket {
    reverse_proxy coolify-realtime:6001
  }

  # Soketi REST API paths
  handle /apps/* {
    reverse_proxy coolify-realtime:6001
  }

  # GitHub webhook callbacks — no auth required
  handle /webhooks/* {
    reverse_proxy coolify:8080 {
      header_up X-Forwarded-Proto https
    }
  }

  # Auth handled by Cloudflare Access — no basic auth needed
  handle {
    reverse_proxy coolify:8080 {
      header_up X-Forwarded-Proto https
    }
  }
}

