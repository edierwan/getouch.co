http://openclaw.getouch.co {
  import common_headers
  header {
    Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Pragma "no-cache"
    Expires "0"
  }

  handle /connect {
    reverse_proxy getouch-web:3000
  }

  handle /reset {
    reverse_proxy getouch-web:3000
  }

  @chat_guard {
    method GET
    path /chat
    not header Upgrade websocket
    not header Cookie *openclaw_boot=1*
  }
  handle @chat_guard {
    reverse_proxy getouch-web:3000
  }

  # Bare root GET (not a WebSocket upgrade): send users to the canonical chat entry.
  @root_redirect {
    method GET
    path /
    not header Upgrade websocket
  }
  redir @root_redirect /chat?session=main 302

  # All other requests (assets, /chat, WebSocket upgrades) → gateway
  handle {
    reverse_proxy openclaw-gateway:18789 {
      flush_interval -1
    }
  }
}

http://s3api.getouch.co {
  import common_headers
  reverse_proxy seaweed-s3:8333
}

http://s3.getouch.co {
  import common_headers

  # Serve custom login page at root and /login to inject SeaweedFS endpoint
  @login {
    not path /api/* /files/* /assets/* /custom.css /admin/* /favicon.ico /sw_cache.js /manifest.json /overrides/*
    not header Cookie *cookie=*
  }
  handle @login {
    root * /etc/caddy/static
    rewrite * /s3-login.html
    file_server
  }

  handle {
    reverse_proxy filestash:8334 {
      header_up X-Forwarded-Proto https
    }
  }
}

