{
  auto_https off
  admin off
}

(common_headers) {
  header {
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy no-referrer-when-downgrade
  }
}

(admin_auth) {
  basic_auth {
    {$ADMIN_AUTH_USER} {$ADMIN_AUTH_HASH}
  }
}

http://getouch.co {
  import common_headers

  # Coolify webhook proxy — bypasses Cloudflare Access on coolify.getouch.co
  handle /webhooks/source/* {
    reverse_proxy coolify:8080 {
      header_up X-Forwarded-Proto https
    }
  }

  handle /services {
    root * /etc/caddy/static
    rewrite * /services.html
    file_server
  }

  # Immutable hashed assets — cache aggressively
  @static path /_next/static/*
  header @static Cache-Control "public, max-age=31536000, immutable"

  # HTML pages — always revalidate
  @html path /
  header @html Cache-Control "public, max-age=0, must-revalidate"

  handle {
    reverse_proxy getouch-web-prod:3000
  }
}

http://dev.getouch.co {
  import common_headers

  @static path /_next/static/*
  header @static Cache-Control "public, max-age=31536000, immutable"

  @html path /
  header @html Cache-Control "public, max-age=0, must-revalidate"

  handle {
    reverse_proxy getouch-web-dev:3000
  }
}

