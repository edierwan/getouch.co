############################################################
# Supabase Staging — Environment Variables
# Stack: Serapod Staging (sb-stg-serapod.getouch.co)
#
# IMPORTANT: Copy this to .env and fill in real values
#            before running `docker compose up -d`
#
# Generate secrets:
#   openssl rand -base64 32        (for most secrets)
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
############################################################

# ── PostgreSQL (dedicated instance, NOT shared with Getouch) ──
POSTGRES_PASSWORD=           # REQUIRED — generate: openssl rand -base64 32
POSTGRES_DB=supabase
POSTGRES_PORT=5432

# ── Supabase JWT ──
# Both ANON and SERVICE_ROLE keys are JWTs signed with this secret.
# Generate: openssl rand -base64 64 | tr -d '\n'
# Then generate keys at: https://supabase.com/docs/guides/self-hosting#api-keys
JWT_SECRET=                  # REQUIRED — used to sign/verify all JWTs
ANON_KEY=                    # REQUIRED — public anon JWT
SERVICE_ROLE_KEY=            # REQUIRED — private service-role JWT

# ── Supabase Studio (Dashboard) ──
DASHBOARD_USERNAME=supabase  # basic-auth user for Studio
DASHBOARD_PASSWORD=          # REQUIRED — generate a strong password

# ── API / Kong gateway ──
# These are the public-facing URLs after reverse proxy
SITE_URL=https://sb-stg-serapod.getouch.co
API_EXTERNAL_URL=https://sb-stg-serapod.getouch.co
SUPABASE_PUBLIC_URL=https://sb-stg-serapod.getouch.co

# ── GoTrue / Auth ──
GOTRUE_SITE_URL=https://sb-stg-serapod.getouch.co
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_SENDER_NAME=Serapod Staging

# ── S3 / Storage ──
# Leave defaults for local storage; override for external S3
STORAGE_BACKEND=file
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ── Logflare / Analytics (optional) ──
LOGFLARE_API_KEY=
LOGFLARE_URL=

# ── Meta / Database connection string (internal) ──
# Auto-composed from POSTGRES_PASSWORD — no manual edit needed
