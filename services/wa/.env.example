# ── WhatsApp API Service (getouch-wa) ──────────────────────
# Required: API key for protected endpoints (legacy single-session)
WA_API_KEY=your-secret-api-key-here
# Optional: separate admin key (defaults to WA_API_KEY)
# WA_ADMIN_KEY=your-admin-key

# ── Multi-session / WAPI integration (Request 05) ──────────
# Shared secret used by WAPI on the X-WAPI-Secret header.
WAPI_SECRET=replace-with-long-random-string
# WAPI webhook receiver. Outbound gateway events are signed with HMAC-SHA256
# of the body using WAPI_SECRET (header X-WA-Signature).
WAPI_WEBHOOK_URL=https://wapi.getouch.co/api/wa/events

# Per-session storage. Each session lives under ${SESSIONS_DIR}/${sessionId}.
# Make sure this is on a persistent volume.
SESSIONS_DIR=/data/sessions

# Default session ID used by the legacy /api/* endpoints.
DEFAULT_SESSION_ID=default

# Optional: limit concurrent sessions (0 = unlimited)
# MAX_CONCURRENT_SESSIONS=20

# Auto-start the default session on boot (default: true).
# AUTO_START_DEFAULT_SESSION=true
# Auto-start every session discovered on disk under SESSIONS_DIR (default: false).
# AUTO_START_SESSIONS=false

# ── Optional: override defaults ────────────────────────────
# PORT=3001
# LOG_LEVEL=info

# ── Legacy migration (one-time) ────────────────────────────
# If WA_AUTH_DIR is set and SESSIONS_DIR/${DEFAULT_SESSION_ID} is empty,
# the gateway will copy creds from WA_AUTH_DIR into the default session
# on boot, so existing single-tenant pairings are preserved.
# WA_AUTH_DIR=/app/data/auth

# ── Dify auto-reply (unchanged) ────────────────────────────
# DIFY_BASE_URL=http://dify-nginx
# DIFY_APP_API_KEY=
# WA_DIFY_AUTO_REPLY_ENABLED=false
# WA_ACTIVE_RESPONDER=true
# WA_DEPLOYMENT_LABEL=production
# AI_TRIGGER_NAME=Sera
