# Getouch Platform – Environment Variables
# Copy to .env and fill in values

# WhatsApp Gateway
WA_PORT=3001
WA_API_KEY=your_api_key_here
WA_ADMIN_KEY=your_admin_key_here
WA_LOG_LEVEL=info

# OpenClaw browser bootstrap
OPENCLAW_GATEWAY_TOKEN=

# PostgreSQL
APP_DB_NAME=getouch.co
APP_DB_USER=getouch
APP_DB_PASSWORD=your_db_password_here

# Caddy Admin Auth
ADMIN_AUTH_USER=getouchadmin
ADMIN_AUTH_HASH=

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@getouch.co
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password_here

# SearXNG
SEARXNG_SECRET=generate_with_openssl_rand_hex_32

# =====================================================
# Protected vLLM API Gateway (vllm.getouch.co)
# =====================================================
# Public OpenAI-compatible endpoint for the internal vLLM backend.
# llm.getouch.co is RESERVED for future LiteLLM and is NOT used here.
#
# Architecture:
#   client -> https://vllm.getouch.co/v1
#          -> Next.js gateway (/v1/* routes)
#          -> http://vllm-qwen3-14b-fp8:8000/v1
#
# Legacy GETOUCH_AI_* env names are still honored as fallbacks.

# Master switch — must be true for /v1/* and /ready to function
GETOUCH_VLLM_GATEWAY_ENABLED=false

# Public base URL advertised in portal UI and used in admin self-tests
GETOUCH_VLLM_PUBLIC_BASE_URL=https://vllm.getouch.co/v1

# Hosts allowed to terminate /v1/* and /health requests
GETOUCH_VLLM_GATEWAY_ALLOWED_HOSTS=vllm.getouch.co,localhost,127.0.0.1

# Comma- or newline-separated API keys.
# Format A: <plain-key>
# Format B: <Label>=<plain-key>
# Format C: <Label>=sha256:<sha256-of-plain-key>
# Never commit real values; use Coolify secrets.
GETOUCH_VLLM_GATEWAY_KEYS=

# Backend type: vllm | ollama | disabled
GETOUCH_VLLM_BACKEND_TYPE=disabled
GETOUCH_VLLM_BACKEND_BASE_URL=http://vllm-qwen3-14b-fp8:8000/v1
GETOUCH_VLLM_BACKEND_API_KEY=

# Safety limits
GETOUCH_VLLM_GATEWAY_TIMEOUT_MS=120000
GETOUCH_VLLM_GATEWAY_MAX_BODY_BYTES=1000000
GETOUCH_VLLM_GATEWAY_MAX_TOKENS=2048
GETOUCH_VLLM_GATEWAY_RATE_LIMIT_REQUESTS=30
GETOUCH_VLLM_GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60

# Optional override of the model alias table.
# Format per entry: alias=backendModel[:type[:status]]
#   type:   chat (default) | embedding
#   status: active (default) | planned | blocked
# Default (when blank) registers:
#   getouch-qwen3-14b -> Qwen/Qwen3-14B-FP8       (chat, planned)
#   getouch-qwen3-30b -> pending-verified-hf-id   (chat, blocked)
#   getouch-embed     -> pending-verified-hf-id   (embedding, planned)
GETOUCH_VLLM_GATEWAY_MODEL_ALIASES=

# Optional admin-only key used by the portal "Test Authenticated Models" button.
# Server-side only; never echoed back to the browser.
GETOUCH_VLLM_GATEWAY_ADMIN_TEST_KEY=
