NIXPACKS_NODE_VERSION=22
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_URL=https://www.example.com
DATA_BACKEND=supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.example.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
CRON_SECRET=replace-with-random-cron-secret
OLLAMA_BASE_URL=https://bot.example.com/ollama
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TOKEN=replace-with-ollama-token
AI_DEFAULT_PROVIDER=ollama
AI_SECRETS_KEY=replace-with-base64-secret
BAILEYS_GATEWAY_URL=https://wa.example.com
MOLTBOT_URL=https://bot.example.com
ELLBOW_SYNC_KEY=replace-with-sync-key
ELLBOW_ORDER_KEY=replace-with-order-key
NEXT_PUBLIC_ACCOUNTING_ENABLED=true